    {
      "id": "FRA_byoushitsu_no_zenei_salon",
      "col": 4,
      "row": 1,
      "icon": "globe",
      "name": {
        "ja": "病室の前衛サロン",
        "en": "Avant-Garde Salon in the Ward"
      },
      "description": {
        "ja": "頭部に重傷を負い奇跡的に生還した詩人は、モンパルナスの病室を新たな精神の拠点とした。既存の秩序に絶望した若き芸術家や退役軍人たちが彼の元に集い、古い世界を嘲笑している。",
        "en": "Miraculously surviving a severe head injury, the poet has turned his Montparnasse hospital room into a new spiritual stronghold. Young artists and veterans, despairing of the existing order, gather around him to mock the old world."
      },
      "effects": {
        "events": [
          {
            "id": "FRA_byoushitsu_no_zenei_salon_event",
            "name": {
              "ja": "アポリネールのカリスマ",
              "en": "Apollinaire's Charisma"
            }
          }
        ]
      },
      "prerequisites": [
        "FRA_dresden_no_kutsujoku"
      ],
      "mutuallyExclusive": []
    },
    {
      "id": "FRA_maya_no_nami_ni_nomarete",
      "col": 6,
      "row": 1,
      "icon": "flame",
      "name": {
        "ja": "マーヤーの波に呑まれて",
        "en": "Swallowed by the Waves of Maya"
      },
      "description": {
        "ja": "インドから到来した神秘思想は、敗戦という受け入れがたい現実に苦しむ民衆の魂に深く突き刺さり、理性主義を破壊しつつある。",
        "en": "The mystical doctrines that arrived from India have pierced deeply into the souls of a populace tormented by the unbearable reality of defeat, eroding and dismantling rationalism in the process."
      },
      "effects": {
        "events": [
          {
            "id": "FRA_maya_no_nami_ni_nomarete_event",
            "name": {
              "ja": "インド文化の流行",
              "en": "Indian Culture Trend"
            }
          }
        ]
      },
      "prerequisites": [
        "FRA_dresden_no_kutsujoku"
      ],
      "mutuallyExclusive": []
    },
    {
      "id": "FRA_jojoutekinaru_coup_detat",
      "col": 5,
      "row": 2,
      "icon": "sword",
      "name": {
        "ja": "抒情的なるクーデター",
        "en": "The Lyrical Coup d'État"
      },
      "description": {
        "ja": "1919年11月、パリ。アポリネール率いる芸術家集団と、彼らに共鳴した退役軍人部隊が蜂起した。",
        "en": "Paris, November 1919. An uprising erupted, led by an artists’ collective under Apollinaire and joined by a detachment of demobilized veterans who had rallied to their cause."
      },
      "effects": {
        "events": [
          {
            "id": "FRA_jojoutekinaru_coup_detat_event",
            "name": {
              "ja": "クーデター発生！",
              "en": "Coup d'État Occurred!"
            }
          }
        ]
      },
      "prerequisites": [
        "FRA_byoushitsu_no_zenei_salon",
        "FRA_maya_no_nami_ni_nomarete"
      ],
      "mutuallyExclusive": []
    },
    {
      "id": "FRA_suukounaru_kuni_no_makuake",
      "col": 5,
      "row": 3,
      "icon": "star",
      "name": {
        "ja": "崇高なる国の幕開け",
        "en": "Dawn of the Sublime State"
      },
      "description": {
        "ja": "古き良きフランス共和国は死んだ。我々はここに、超現実主義と神秘主義が支配する「崇高なる国」の誕生を宣言する。",
        "en": "The old French Republic is dead. We hereby declare the birth of 'La Sublime,' a nation ruled by surrealism and mysticism."
      },
