    {
      "id": "FRA_dresden_no_kutsujoku",
      "col": 5,
      "row": 0,
      "icon": "anchor",
      "name": {
        "ja": "ドレスデンの屈辱",
        "en": "The Humiliation of Dresden"
      },
      "description": {
        "ja": "1914年のドレスデン講和会議は、我が国から多くの領土と富を奪い去った。",
        "en": "The 1914 Dresden Peace Conference stripped our nation of its territories and wealth."
      },
      "effects": {
        "events": [
          {
            "id": "FRA_dresden_no_kutsujoku_event",
            "name": {
              "ja": "敗戦処理",
